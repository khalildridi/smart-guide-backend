PORT=4000
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
DEBUG_ROUTES_ENABLED=false
PROXY_ALLOWED_TABLES=plans,reviews,profiles,user_badges,notifications
PROXY_AUTH_REQUIRED_TABLES=notifications
FUNCTION_ALLOWED_NAMES=ai-recommendations,contact-form,notify-admin-report
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=180
RATE_LIMIT_WRITE_WINDOW_MS=60000
RATE_LIMIT_WRITE_MAX_REQUESTS=50

# Optional E2E credentials (used by npm run e2e:critical from project root)
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
